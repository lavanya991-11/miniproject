PORT=5000
JWT_SECRET=your_jwt_secret_here
DB_CONNECTION_STRING=Server=tcp:your-server.database.windows.net,1433;Initial Catalog=your-database;Persist Security Info=False;User ID=your-user;Password=your-password;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;
# Or use individual variables:
# DB_SERVER=your-server.database.windows.net
# DB_NAME=your-database
# DB_USER=your-user
# DB_PASSWORD=your-password
# DB_PORT=1433
# DB_ENCRYPT=true
